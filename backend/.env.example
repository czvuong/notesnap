# ── AI Provider ───────────────────────────────────────────────────────────────
# "tritonai" uses the two-step pipeline:
#   1. api-lightonocr-1b   →  free OCR (image → raw text)
#   2. api-gpt-oss-120b    →  structuring, flashcards, Q&A (text-only input)
# If OCR fails, falls back to TRITONAI_VISION_MODEL which supports image input.
# "anthropic" uses Claude vision as a single-step alternative.
AI_PROVIDER=tritonai

# ── TritonAI (UCSD) ───────────────────────────────────────────────────────────
TRITONAI_API_KEY=your-tritonai-api-key-here
TRITONAI_BASE_URL=https://tritonai-api.ucsd.edu/v1

# Step 1: OCR layer — free on input, extracts raw text from images
TRITONAI_OCR_MODEL=api-lightonocr-1b

# Step 2: Text model — structures notes, generates flashcards & Q&A
# NOTE: api-gpt-oss-120b has NO Vision capability — text input only
TRITONAI_TEXT_MODEL=api-gpt-oss-120b

# Vision fallback — used when OCR model is unavailable
# api-mistral-small-3.2-2506 supports both image (Vision) and text input
TRITONAI_VISION_MODEL=api-mistral-small-3.2-2506

# ── Anthropic (fallback) ──────────────────────────────────────────────────────
# Only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./notesnap.db

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_BYTES=10485760
SOFT_DELETE_TTL_DAYS=7
