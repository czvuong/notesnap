# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose "tritonai" or "anthropic"
AI_PROVIDER=tritonai

# TritonAI (OpenAI-compatible via LiteLLM)
TRITONAI_API_KEY=your-tritonai-key-here
TRITONAI_BASE_URL=https://tritonai.ucsd.edu/api/v1   # confirm exact URL from their docs
TRITONAI_MODEL=gpt-4o                                 # replace with whichever vision model they expose

# Anthropic direct (fallback)
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite file — relative to backend/ directory
DATABASE_URL=sqlite:///./notesnap.db

# ── Server ────────────────────────────────────────────────────────────────────
# Origins allowed to call the API (your React dev server)
CORS_ORIGINS=http://localhost:5173

# Max upload size in bytes (default: 10 MB)
MAX_UPLOAD_BYTES=10485760

# ── Soft-delete cleanup ───────────────────────────────────────────────────────
# How many days before a soft-deleted record is permanently removed
SOFT_DELETE_TTL_DAYS=7
